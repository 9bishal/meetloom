{
  "name": "meetloom-api",
  "runtimeStack": "NODE|20",
  "alwaysOn": true,
  "httpLoggingEnabled": true,
  "numberOfWorkers": 1,
  "defaultDocuments": [],
  "remoteDebuggingEnabled": false,
  "requestTracingEnabled": true,
  "requestTracingExpirationTime": "9999-12-31T23:59:59Z",
  "detailedErrorLoggingEnabled": true,
  "webSocketsEnabled": false,
  "managedPipelineMode": 0,
  "virtualApplications": [
    {
      "virtualPath": "/",
      "physicalPath": "site\\wwwroot",
      "preloadEnabled": true
    }
  ],
  "loadBalancing": 1,
  "experiments": {
    "rampUpRules": []
  },
  "autoHealEnabled": true,
  "autoHealRules": {
    "triggers": {
      "statusCodes": [
        {
          "status": 500,
          "count": 10,
          "timeInterval": "00:01:00"
        }
      ]
    },
    "actions": {
      "actionType": "Recycle",
      "minProcessExecutionTime": "00:01:00"
    }
  },
  "scmType": "GitHub",
  "appSettingsToHide": [
    "GROK_API_KEY",
    "OPENAI_API_KEY",
    "API_KEY"
  ],
  "connectionStrings": []
}
